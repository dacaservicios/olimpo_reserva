<!-- Loader -->
<div id="global-loader">
    <div class="spinner-border" role="status"></div>
</div>

<!-- Android Login Screen -->
<div class="android-login-screen">

    <!-- Hero: logo + nombre -->
    <div class="login-hero">
        <div class="login-logo-ring">
            <img src="/imagenes/logo.png" alt="Olimpo">
        </div>
        <h1 class="login-app-name">Olimpo<em>Barber</em></h1>
        <p class="login-tagline">Sistema de Reservas</p>
    </div>

    <!-- Card del formulario -->
    <div class="login-card">
        <h2 class="login-title">Iniciar sesión</h2>
        <p class="login-subtitle">Ingresa tus credenciales para continuar</p>

        <form id="login" class="needs-validation" novalidate>

            <div class="login-field">
                <label>Correo electrónico</label>
                <div class="login-input-wrapper">
                    <i class="las la-envelope input-icon"></i>
                    <input class="form-control" name="txtCorreo"
                        placeholder="ejemplo@correo.com" type="text" autocomplete="email" required>
                </div>
                <div class="vacio oculto">¡Campo obligatorio!</div>
                <div class="formato oculto">¡Formato incorrecto!</div>
            </div>

            <div class="login-field">
                <label>Contraseña</label>
                <div class="login-input-wrapper">
                    <i class="las la-lock input-icon"></i>
                    <input class="form-control" name="txtContrasena"
                        placeholder="••••••••" type="password" autocomplete="current-password" required>
                    <span id="verPass" class="login-eye" title="Mostrar/ocultar">
                        <i class="las la-low-vision"></i>
                    </span>
                </div>
                <div class="vacio oculto">¡Campo obligatorio!</div>
                <div class="formato oculto">¡Formato incorrecto!</div>
            </div>

            <button type="button" class="submit btn btn-primary login-btn w-100">
                <i class="las la-sign-in-alt"></i>
                Iniciar sesión
            </button>

        </form>

        <p class="login-footer-text">© 2025 AyniSystem · Olimpo Barbería</p>
    </div>

</div>

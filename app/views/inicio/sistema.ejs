<!-- Loader -->
<div id="global-loader">
    <div class="spinner-border" role="status"></div>
</div>

<!-- Hidden session inputs -->
<input type="hidden" id="userSesion"   value="<%= user.id%>">
<input type="hidden" id="userSucursal" value="">
<input type="hidden" id="userNivel"    value="">

<!-- Script loader -->
<div id="jsPropio"></div>

<!-- ═══════════════════════════════
     TOP APP BAR
════════════════════════════════ -->
<header class="android-top-bar">
    <div class="brand" onclick="irReservas()">
        <img src="/imagenes/logo.png" alt="Olimpo" class="imagenUsuarioInicio">
        <span class="brand-name">Olimpo</span>
    </div>
</header>

<!-- ═══════════════════════════════
     MAIN CONTENT
════════════════════════════════ -->
<main class="android-content">
    <div id="cuerpoPrincipal" class="main-container container-fluid"></div>
</main>

<!-- ═══════════════════════════════
     BOTTOM NAVIGATION
════════════════════════════════ -->
<nav class="android-bottom-nav">
    <button class="md-nav-item active" id="navReservas" onclick="irReservas()">
        <div class="md-nav-pill"></div>
        <i class="las la-calendar-alt md-nav-icon"></i>
        <span class="md-nav-label">Reservas</span>
    </button>
    <button class="md-nav-item" id="navMisCitas" onclick="abrirMisCitas()">
        <div class="md-nav-pill"></div>
        <i class="las la-calendar-check md-nav-icon"></i>
        <span class="md-nav-label">Mis Citas</span>
    </button>
    <button class="md-nav-item" id="navPerfil"
        data-bs-toggle="offcanvas" data-bs-target="#offcanvasProfile">
        <div class="md-nav-pill"></div>
        <i class="las la-user-circle md-nav-icon"></i>
        <span class="md-nav-label">Perfil</span>
    </button>
</nav>

<!-- ═══════════════════════════════
     OFFCANVAS — PERFIL
════════════════════════════════ -->
<div class="offcanvas offcanvas-end" tabindex="-1" id="offcanvasProfile">
    <div class="offcanvas-header">
        <h5 class="offcanvas-title">Mi Cuenta</h5>
        <button type="button" class="btn-close" data-bs-dismiss="offcanvas"></button>
    </div>
    <div class="offcanvas-body">
        <div class="md-profile-header">
            <img class="md-profile-avatar imagenUsuarioInicio" src="/imagenes/logo.png" alt="Avatar">
            <div>
                <div class="md-profile-name" id="usuarioMenu2">—</div>
                <div class="md-profile-role" id="nivelMenu2">Barbería</div>
            </div>
        </div>
        <div style="display:flex;flex-direction:column;gap:4px;">
            <a id="cambiaPassword" href="#" class="md-list-item" data-bs-dismiss="offcanvas"
               onclick="setTimeout(abrirCambiaPasswordPanel,350)">
                <i class="bx bx-lock-alt"></i>
                <span>Cambiar contraseña</span>
            </a>
            <a id="salir" href="#" class="md-list-item danger">
                <i class="bx bx-log-out"></i>
                <span>Cerrar sesión</span>
            </a>
        </div>
    </div>
</div>

<!-- ═══════════════════════════════
     OFFCANVAS — MIS CITAS
════════════════════════════════ -->
<div class="offcanvas offcanvas-end" tabindex="-1" id="offcanvasMisCitas">
    <div class="offcanvas-header">
        <h5 class="offcanvas-title"><i class="las la-calendar-check me-2"></i>Mis Citas</h5>
        <button type="button" class="btn-close" data-bs-dismiss="offcanvas"></button>
    </div>
    <div class="offcanvas-body" id="misCitasBody">
        <div class="md-cal-empty">
            <i class="las la-spinner la-spin"></i>
            <p>Cargando...</p>
        </div>
    </div>
</div>

<!-- ═══════════════════════════════
     OFFCANVAS — CAMBIAR CONTRASEÑA
════════════════════════════════ -->
<div class="offcanvas offcanvas-end" tabindex="-1" id="offcanvasPassword">
    <div class="offcanvas-header">
        <h5 class="offcanvas-title"><i class="bx bx-lock-alt me-2"></i>Cambiar Contraseña</h5>
        <button type="button" class="btn-close" data-bs-dismiss="offcanvas"></button>
    </div>
    <div class="offcanvas-body">
        <form id="formCambiaPass" novalidate autocomplete="off">
            <div class="mb-3">
                <label>Contraseña actual</label>
                <div class="md-pass-wrap">
                    <input id="passActualInput" name="contrasenaActual" type="password"
                           class="form-control" maxlength="50" placeholder="Contraseña actual">
                    <button type="button" class="md-pass-toggle" data-target="passActualInput">
                        <i class="las la-eye-slash"></i>
                    </button>
                </div>
                <div class="md-pass-msg" id="msgPassActual"></div>
            </div>
            <div class="mb-3">
                <label>Contraseña nueva</label>
                <div class="md-pass-wrap">
                    <input id="passNuevaInput" name="contrasenaNueva" type="password"
                           class="form-control" maxlength="50" placeholder="Contraseña nueva">
                    <button type="button" class="md-pass-toggle" data-target="passNuevaInput">
                        <i class="las la-eye-slash"></i>
                    </button>
                </div>
                <div class="md-pass-reqs">
                    <span class="req-item" id="reqLen">6–16 chars</span>
                    <span class="req-item" id="reqNum">Número</span>
                    <span class="req-item" id="reqMay">Mayúscula</span>
                    <span class="req-item" id="reqMin2">Minúscula</span>
                    <span class="req-item" id="reqEsp">Especial</span>
                </div>
                <div class="md-pass-msg" id="msgPassNueva"></div>
            </div>
            <div class="mb-4">
                <label>Repite contraseña nueva</label>
                <div class="md-pass-wrap">
                    <input id="passRepiteInput" name="contrasenaRepite" type="password"
                           class="form-control" maxlength="50" placeholder="Repite la contraseña">
                    <button type="button" class="md-pass-toggle" data-target="passRepiteInput">
                        <i class="las la-eye-slash"></i>
                    </button>
                </div>
                <div class="md-pass-msg" id="msgPassRepite"></div>
            </div>
            <button type="button" id="btnGuardaPass" class="md-pass-btn-save w-100">
                <i class="bx bx-save me-1"></i> Guardar contraseña
            </button>
        </form>
    </div>
</div>

<script>
// Navegación bottom bar
function setNavActive(id) {
    document.querySelectorAll('.md-nav-item').forEach(function(el) {
        el.classList.remove('active');
    });
    var el = document.getElementById(id);
    if (el) el.classList.add('active');
}

function irReservas() {
    setNavActive('navReservas');
    vistaMenuSubMenu({ ruta: 'reserva', idSubMenu: 88 });
}

function irInicio() {
    setNavActive('navApps');
    vistaMenuSubMenu({ ruta: 'inicio', idSubMenu: 1 });
}

function irModulo(ruta, idSubMenu) {
    setNavActive('navApps');
    vistaMenuSubMenu({ ruta: ruta, idSubMenu: idSubMenu || 0 });
}

// ── Cambiar contraseña ──────────────────────────────────────────────────
function abrirCambiaPasswordPanel() {
    var el = document.getElementById('offcanvasPassword');
    var offcanvas = bootstrap.Offcanvas.getOrCreateInstance(el);

    // Limpiar formulario
    document.getElementById('formCambiaPass').reset();
    ['msgPassActual','msgPassNueva','msgPassRepite'].forEach(function(id){
        document.getElementById(id).textContent = '';
        document.getElementById(id).style.display = 'none';
    });
    ['reqLen','reqNum','reqMay','reqMin2','reqEsp'].forEach(function(id){
        document.getElementById(id).classList.remove('met');
    });

    // Restaurar tipo password e ícono de toggles
    ['passActualInput','passNuevaInput','passRepiteInput'].forEach(function(id){
        var inp = document.getElementById(id);
        inp.type = 'password';
        var btn = inp.parentElement.querySelector('.md-pass-toggle i');
        if (btn) { btn.className = 'las la-eye-slash'; }
    });

    offcanvas.show();
    _setupPassEvents();
}

function _setupPassEvents() {
    var form = document.getElementById('formCambiaPass');

    // Toggle visibilidad
    form.querySelectorAll('.md-pass-toggle').forEach(function(btn){
        btn.onclick = function(){
            var inp = document.getElementById(btn.dataset.target);
            var ic  = btn.querySelector('i');
            if (inp.type === 'password') {
                inp.type = 'text';
                ic.className = 'las la-eye';
            } else {
                inp.type = 'password';
                ic.className = 'las la-eye-slash';
            }
        };
    });

    // Validación en tiempo real — contraseña nueva
    document.getElementById('passNuevaInput').oninput = function(){
        _passCheckReqs(this.value);
    };

    // Botón guardar
    document.getElementById('btnGuardaPass').onclick = _passGuardar;
}

function _passCheckReqs(val) {
    var especiales = '!¡#$%&()*+-./:;=¿?@[]{|}';
    var ok = {
        len: val.length >= 6 && val.length <= 16,
        num: /[0-9]/.test(val),
        may: /[A-ZÁÉÍÓÚÑ]/.test(val),
        min: /[a-záéíóúñ]/.test(val),
        esp: val.split('').some(function(c){ return especiales.indexOf(c) !== -1; })
    };
    document.getElementById('reqLen').classList.toggle('met', ok.len);
    document.getElementById('reqNum').classList.toggle('met', ok.num);
    document.getElementById('reqMay').classList.toggle('met', ok.may);
    document.getElementById('reqMin2').classList.toggle('met', ok.min);
    document.getElementById('reqEsp').classList.toggle('met', ok.esp);
    return ok.len && ok.num && ok.may && ok.min && ok.esp;
}

function _passShowMsg(id, msg) {
    var el = document.getElementById(id);
    el.textContent = msg;
    el.style.display = msg ? 'block' : 'none';
}

async function _passGuardar() {
    var actual  = document.getElementById('passActualInput').value.trim();
    var nueva   = document.getElementById('passNuevaInput').value.trim();
    var repite  = document.getElementById('passRepiteInput').value.trim();

    _passShowMsg('msgPassActual','');
    _passShowMsg('msgPassNueva','');
    _passShowMsg('msgPassRepite','');

    if (!actual)  { _passShowMsg('msgPassActual','Campo obligatorio'); return; }
    if (!nueva)   { _passShowMsg('msgPassNueva','Campo obligatorio'); return; }
    if (!_passCheckReqs(nueva)) { _passShowMsg('msgPassNueva','La contraseña no cumple los requisitos'); return; }
    if (!repite)  { _passShowMsg('msgPassRepite','Campo obligatorio'); return; }
    if (nueva !== repite) { _passShowMsg('msgPassRepite','Las contraseñas no coinciden'); return; }

    bloquea();
    try {
        const vResp = await axios.put('/api/acceso/verificaPass/' + verSesion(),
            { contrasenaActual: actual },
            { headers: { authorization: 'Bearer ' + verToken() } }
        );
        desbloquea();
        if (!vResp.data.valor.resultado) {
            _passShowMsg('msgPassActual', vResp.data.valor.mensaje || 'Contraseña incorrecta');
            return;
        }

        bloquea();
        const cResp = await axios.put('/api/acceso/password/' + verSesion(),
            { contrasenaNueva: nueva },
            { headers: { authorization: 'Bearer ' + verToken() } }
        );
        desbloquea();
        if (cResp.data.valor.resultado) {
            bootstrap.Offcanvas.getInstance(document.getElementById('offcanvasPassword')).hide();
            Swal.fire({ icon: 'success', title: '¡Contraseña actualizada!', timer: 2000, showConfirmButton: false, toast: true, position: 'top' });
        } else {
            _passShowMsg('msgPassNueva', cResp.data.valor.mensaje || 'Error al cambiar');
        }
    } catch(err) {
        desbloquea();
        var msg = (err.response && err.response.data && err.response.data.error)
                  ? err.response.data.error.message : 'Error de conexión';
        _passShowMsg('msgPassActual', msg);
    }
}
</script>
